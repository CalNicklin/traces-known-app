{
  "name": "@acme/nextjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "pnpm with-env next dev --turbopack",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm mcp\"",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "mcp": "pnpm with-env tsx src/mcp-server.ts",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@acme/api": "workspace:*",
    "@acme/auth": "workspace:*",
    "@acme/db": "workspace:*",
    "@acme/ui": "workspace:*",
    "@acme/validators": "workspace:*",
    "@ai-sdk/mcp": "1.0.0-beta.24",
    "@ai-sdk/openai": "^2.0.74",
    "@ai-sdk/rsc": "^1.0.105",
    "@heroicons/react": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@t3-oss/env-nextjs": "^0.13.6",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "ai": "^5.0.104",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "next": "^15.3.3",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "superjson": "2.2.2",
    "use-debounce": "^10.0.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.29",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "catalog:",
    "jiti": "^2.4.2",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "^4.20.0",
    "typescript": "catalog:",
    "vitest": "^2.1.4"
  },
  "prettier": "@acme/prettier-config"
}
