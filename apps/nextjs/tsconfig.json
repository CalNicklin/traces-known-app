{
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@acme/api": ["../../packages/api/src/index.ts"],
      "@acme/api/*": ["../../packages/api/src/*"],
      "@acme/api/sdui-schema": ["../../packages/api/src/sdui-schema"]
    },
    "plugins": [{ "name": "next" }],
    "module": "esnext"
  },
  "include": [".", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
